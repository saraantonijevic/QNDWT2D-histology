function a = copy_fields_local(a, b)

fn = fieldnames(b);
for i = 1:numel(fn)
    a.(fn{i}) = b.(fn{i});
end

end

% Quaternion nondecimated filtering
%LL = H^* A H
%LH = H^* A G
%HL = G^* A H
%HH = G^* A G

function Y = apply_right_q_local(M, f, shift)
% Computes M * F ; each filter tap multiplies pixels on the right

Y = zeros(size(M));
K = size(f,1);

for r = 0:(K-1)
    q = f(r+1,:);
    if any(q ~= 0)
        Ms = circshift(M, [0, -(shift+r), 0]);
        Y = Y + qmul_right_scalar_local(Ms, q);
    end
end

end

function Y = apply_left_adjoint_q_local(M, f, shift)
%computes F^* * M. Each conjugated filter tap multiplies pixels on the left


Y = zeros(size(M));
K = size(f,1);

for r = 0:(K-1)
    q = qconj_scalar_local(f(r+1,:));
    if any(q ~= 0)
        Ms = circshift(M, [-(shift+r), 0, 0]);
        Y = Y + qmul_left_scalar_local(q, Ms);
    end
end

end

function filtd = dilate_qfilter_local(filt, gap)
% Insert gap zero quaternion taps between adjacent taps.

if gap < 1
    filtd = filt;
    return
end

K = size(filt,1);
newlength = (gap + 1) * K - gap;
filtd = zeros(newlength,4);
filtd(1:(gap+1):newlength,:) = filt;

end

function qc = qconj_scalar_local(q)

qc = [q(1), -q(2), -q(3), -q(4)];

end

function Y = qmul_right_scalar_local(X, q)
% Right multiplication: X * q

a = X(:,:,1);
b = X(:,:,2);
c = X(:,:,3);
d = X(:,:,4);

e = q(1);
f = q(2);
g = q(3);
h = q(4);

Y = zeros(size(X));
Y(:,:,1) = a*e - b*f - c*g - d*h;
Y(:,:,2) = a*f + b*e + c*h - d*g;
Y(:,:,3) = a*g - b*h + c*e + d*f;
Y(:,:,4) = a*h + b*g - c*f + d*e;

end

function Y = qmul_left_scalar_local(q, X)
%left multiplication: q * X

e = q(1);
f = q(2);
g = q(3);
h = q(4);

a = X(:,:,1);
b = X(:,:,2);
c = X(:,:,3);
d = X(:,:,4);

Y = zeros(size(X));
Y(:,:,1) = e*a - f*b - g*c - h*d;
Y(:,:,2) = e*b + f*a + g*d - h*c;
Y(:,:,3) = e*c - f*d + g*a + h*b;
Y(:,:,4) = e*d + f*c - g*b + h*a;

end



function [h, g] = qfletcher10_local() %Fletcher-10 quaternion filter
% Fletcher-10 quaternion scaling and wavelet filters
%rows are [a b c d] = a + b*i + c*j + d*k

h = zeros(10,4);
g = zeros(10,4);

h(1,:) = [-0.0115088994, -0.0200400312,  0, 0];
h(2,:) = [-0.0391302581,  0.0224723305,  0, 0.0166753392];
h(3,:) = [ 0.0073656956,  0.2076972100,  0,  0.0500260177];
h(4,:)= [ 0.2393851082,  0.1226724866,  0, 0.0166753392];
h(5,:) = [ 0.5109951348, -0.3328019959,  0, -0.0833766962];
h(6,:)= h(5,:);
h(7,:)  = h(4,:);
h(8,:)= h(3,:);
h(9,:) = h(2,:);
